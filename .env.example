# AgentSwarm Environment Variables
# Copy this file to .env and adjust values for your environment

# ── LLM Backend ──
AGENTSWARM_LLM_BASE_URL=http://localhost:11434/v1
AGENTSWARM_LLM_API_KEY=ollama
AGENTSWARM_DECOMPOSER_MODEL=qwen3.5:35b
AGENTSWARM_DEFAULT_MODEL=qwen3.5:35b

# ── Data & Storage ──
# AGENTSWARM_DATA_DIR=./data           # SQLite DB, settings, workspaces, traces
# AGENTSWARM_CHECKPOINT_DIR=./checkpoints  # Task checkpoint JSONs
